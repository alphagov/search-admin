<div class="govuk-grid-row actions">
  <div class="govuk-grid-column-two-thirds">
    <%= render "page_title", title: t(".page_title") %>
  </div>

  <div class="govuk-grid-column-one-third app-actions__count">
    <%= render "govuk_publishing_components/components/button", {
      text: t("common.buttons.new", model_name: t_model_name),
      href: new_denylist_entry_path,
      inline_layout: true
    } %>
    <div class="app-actions__count">
      Currently using <%= number_with_delimiter(@total_count) %> entries out of a maximum of
      <%= number_with_delimiter(DenylistEntry::MAX_ENTRIES) %>
    </div>
  </div>
</div>

<%= render "govuk_publishing_components/components/tabs", {
  as_links: true,
  tabs: DenylistEntry.categories.map do |category, _|
    {
      href: denylist_entries_path(category: category),
      label: t(category, scope: "activerecord.attributes.denylist_entry.category_values"),
      active: @category_filter == category
    }
  end,
} %>

<div class="govuk-!-margin-top-6 app-table__container" data-module="filterable-table">
  <%= render "govuk_publishing_components/components/table", {
    filterable: true,
    label: t(".filter_table_label"),
    head: [
      { text: t_model_attr(:phrase) },
      { text: t_model_attr(:match_type) },
      { text: t_model_attr(:updated_at) },
      { text: t_model_attr(:actions) },
    ],
    rows: @denylist_entries.map do |denylist_entry|
      [
        { text: capture do
          concat denylist_entry_phrase_with_visible_spaces(denylist_entry)
          if denylist_entry.comment?
            concat tag.span(denylist_entry.comment, class: "app-denylist-entry-comment")
          end
        end },
        { text: denylist_entry_match_type_tag(denylist_entry) },
        { text: denylist_entry.updated_at.to_fs(:govuk) },
        { text: capture do
          concat render "govuk_publishing_components/components/button", {
            text: t(".buttons.edit", model_name: t_model_name),
            href: edit_denylist_entry_path(denylist_entry),
            inline_layout: true,
            secondary_solid: true,
          }
          concat delete_button(
            t(".buttons.delete", model_name: t_model_name),
            denylist_entry,
            is_inline: true
          )
        end }
      ]
    end
  } %>
</div>
