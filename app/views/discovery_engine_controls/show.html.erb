<%= render "govuk_publishing_components/components/breadcrumbs", {
  breadcrumbs: [
    {
      title: @discovery_engine_control.model_name.human.pluralize,
      url: discovery_engine_controls_path
    },
    {
      title: @discovery_engine_control.name
    }
  ]
} %>

<%= render "common/page_title", title: @discovery_engine_control.name %>

<div class="actions">
  <%= render "govuk_publishing_components/components/button", {
    text: "Edit #{@discovery_engine_control.model_name.human}",
    href: edit_discovery_engine_control_path(@discovery_engine_control),
    inline_layout: true
  } %>
  <%= delete_button "Delete #{@discovery_engine_control.model_name.human}", discovery_engine_control_path(@discovery_engine_control), is_inline: true %>
</div>

<%= render @discovery_engine_control %>
