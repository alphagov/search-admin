<%= form_with(model: discovery_engine_control) do |form| %>
  <% if discovery_engine_control.errors.any? %>
    <%= render "govuk_publishing_components/components/error_summary", {
      id: "error-summary",
      title: "There is a problem",
      description: "The #{human_record_name} could not be updated because some fields are missing or incorrect.",
      items: error_summary_items(discovery_engine_control)
    } %>
  <% end %>

  <%= render "govuk_publishing_components/components/input", {
    label: {
      text: human_attribute_name(:name)
    },
    id: "discovery_engine_control_name",
    name: "discovery_engine_control[name]",
    value: discovery_engine_control.name,
    error_items: error_items(discovery_engine_control, :name)
  } %>

  <%= render "govuk_publishing_components/components/radio", {
    id: "discovery_engine_control_action",
    name: "discovery_engine_control[action]",
    heading: human_attribute_name(:action),
    heading_size: "s",
    small: true,
    items: discovery_engine_control.class.actions.map do |action, _|
      {
        text: t(action, scope: "activerecord.attributes.discovery_engine_control.actions"),
        value: action,
        checked: discovery_engine_control.action == action
      }
    end
  } %>

  <%= render "govuk_publishing_components/components/input", {
    label: {
      text: human_attribute_name(:filter)
    },
    id: "discovery_engine_control_filter",
    name: "discovery_engine_control[filter]",
    value: discovery_engine_control.filter,
    error_items: error_items(discovery_engine_control, :filter)
  } %>

  <%= render "govuk_publishing_components/components/input", {
    label: {
      text: human_attribute_name(:boost_amount)
    },
    id: "discovery_engine_control_boost_amount",
    name: "discovery_engine_control[boost_amount]",
    value: discovery_engine_control.boost_amount,
    error_items: error_items(discovery_engine_control, :boost_amount)
  } %>

  <%= hidden_field_tag "discovery_engine_control[active]", "0" %>
  <%= render "govuk_publishing_components/components/checkboxes", {
    id: "discovery_engine_control_active",
    name: "discovery_engine_control[active]",
    heading: human_attribute_name(:active),
    small: true,
    no_hint_text: true,
    visually_hide_heading: true,
    items: [
      {
        label: human_attribute_name(:active),
        value: "1",
        checked: discovery_engine_control.active?
      }
    ]
  } %>

  <%= render "govuk_publishing_components/components/button", {
    text: "Save"
  } %>
<% end %>
